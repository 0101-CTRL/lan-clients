[Unit]
Description=APIv3 LAN Clients Console
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/api-v3-lan-clients-ui
Environment=HOST=0.0.0.0
Environment=PORT=8093
ExecStart=/opt/api-v3-lan-clients-ui/run_local.sh
Restart=always
RestartSec=3
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
